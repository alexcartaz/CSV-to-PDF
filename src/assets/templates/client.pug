<!DOCTYPE html>
- let client = formattedClientData
- let people = formattedPeopleData
html
    head
        style #{clientCSS}
    body
    .container
        .logo
        .spacer
        .header Generic Consulting Co
            br 
            | 777 Lucky Dr
            br 
            | New York, NY 10002
            br 
            | (555) 111-2222
            br 
            a(href='finance@genericconsulting.co') finance@genericconsulting.co
            br 
            a(href='www.genericconsulting.co') www.genericconsulting.co
        .text1 INVOICE
        .leftText BILL TO
            br 
            | #{client.subJobcode}
        .midText INVOICE
            br 
            | DATE
            br 
            | TERMS
            br 
            | DUE DATE
        .rightText 0000
            br 
            | #{client.lastDayOfMonth}
            br 
            | Net 30 
            br 
            | #{client.lastDayofMonthPlus30Days}
        table(class='tableHeader')
            tr
                th(class="desc") DESCRIPTION
                th(class="qty") QTY
                th(class="rate") RATE
                th(class="amt") AMOUNT
        .text2 Charges
        .text3 #{client.mainJobcode}
            br 
            | #{client.subJobcode}
            br 
            | #{client.monthYear}
            br 
            | Voucher #000000

        table(class='tableIterate')
            each person in people
                tr 
                    td(class='desc') #{person.name}, #{person.title}
                    td(class='qty') #{person.totalHours}
                    td(class='rate') #{person.rate}
                    td(class='amt') #{person.totalAmount}
            if client.expenses
                tr
                    td(class='desc') #{client.expensesDesc}
                    td(class='qty') #{client.expensesQTY}
                    td(class='rate') #{client.expensesRate}
                    td(class='amt') #{client.expensesAmt}
            if client.contractor
                tr 
                    td(class='desc') #{client.contractorDesc}
                    td(class='qty') #{client.contractorQTY}
                    td(class='rate') #{client.contractorRate}
                    td(class='amt') #{client.contractorAmt}

        .footer
            .footerLeft Please make a check payable to Generic Consulting Co
                br 
                | Please note our new address above.
                br 
                | My employer identification number is 00-2222222.
                br 
                | I certify that the invoiced services have been performed in
                br 
                | accordance with our Scope of Services and that hours and/or other
                br 
                | costs are true, correct and have not been previously billed.
                br 
                | Thank you for this opportunity to work with you.
                br 
                | Sincerely,
                br 
                | John Smith, CEO
            .footerMiddle BALANCE DUE
            .footerRight $#{client.total}